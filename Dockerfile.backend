# Use a lightweight Python base image
FROM python:3.10-slim

# Set the working directory
WORKDIR /app

# Copy the requirements first to leverage Docker's cache
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy the backend code (specifically app.py)
COPY app.py .
COPY .env .

# Expose the API port
EXPOSE 5000

# Run the Flask app
CMD ["python", "app.py"]
